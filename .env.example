# PMOS environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---- Core ----
APP_ENV=development            # development | staging | production
LOG_LEVEL=info                 # debug | info | warn | error
PORT=8080

# ---- LLM provider (Anthropic) ----
ANTHROPIC_API_KEY=
# Default model for agents. See docs for supported models.
PMOS_MODEL=claude-opus-4-8
PMOS_MAX_TOKENS=4096

# ---- Database ----
DATABASE_URL=postgresql://pmos:pmos@localhost:5432/pmos

# ---- Vector store / knowledge base ----
VECTOR_DB_URL=http://localhost:6333
KNOWLEDGE_INDEX=pmos-knowledge

# ---- Cache / queue ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth & security ----
JWT_SECRET=change-me
SESSION_SECRET=change-me

# ---- Integrations (optional) ----
SLACK_BOT_TOKEN=
JIRA_BASE_URL=
JIRA_API_TOKEN=
GITHUB_TOKEN=
